<?xml version="1.0" encoding="utf-8"?>
<!-- Lets plain HTTP reach LAN IPs during development (Docker gateway).
     Prefer HTTPS for production builds and tighten this config instead. -->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
