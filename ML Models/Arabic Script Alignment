## Step 8: Transcribe with Automatic Chunking

This processes audio in chunks to avoid memory issues.
def transcribe_with_chunking(audio_array, chunk_length_seconds=20, overlap_seconds=1):
    """
    Transcribe audio in chunks with memory management.

    Args:
        audio_array: Audio data
        chunk_length_seconds: Length of each chunk (reduce if still getting OOM)
        overlap_seconds: Overlap between chunks for continuity
    """
    sample_rate = 16000
    chunk_size = chunk_length_seconds * sample_rate
    overlap_size = overlap_seconds * sample_rate

    transcriptions = []
    total_chunks = int(np.ceil(len(audio_array) / (chunk_size - overlap_size)))

    print(f"Processing {total_chunks} chunks of ~{chunk_length_seconds} seconds each...\n")

    for i in range(0, len(audio_array), chunk_size - overlap_size):
        chunk_num = i // (chunk_size - overlap_size) + 1
        chunk = audio_array[i:i + chunk_size]

        # Skip if chunk is too short
        if len(chunk) < sample_rate * 0.5:  # Less than 0.5 seconds
            continue

        print(f"Chunk {chunk_num}/{total_chunks} ({len(chunk)/sample_rate:.1f}s)...", end=" ")

        try:
            # Clear cache before processing
            if torch.cuda.is_available():
                torch.cuda.empty_cache()
            gc.collect()

            # Process chunk
            audio_inputs = processor(
                audios=chunk,
                sampling_rate=sample_rate,
                return_tensors="pt"
            ).to(device)

            # Generate transcription with memory-efficient settings
            with torch.no_grad():
                output_tokens = model.generate(
                    **audio_inputs,
                    tgt_lang="arz",
                    generate_speech=False,
                    max_new_tokens=256  # Limit output length
                )

            # Decode
            chunk_transcription = processor.decode(
                output_tokens[0].tolist()[0],
                skip_special_tokens=True
            )

            transcriptions.append(chunk_transcription)
            print(f"✓ Done")

            # Clean up
            del audio_inputs, output_tokens
            if torch.cuda.is_available():
                torch.cuda.empty_cache()

        except Exception as e:
            print(f"✗ Error: {str(e)}")
            # Try to continue with smaller chunk if possible
            continue

    return " ".join(transcriptions)

