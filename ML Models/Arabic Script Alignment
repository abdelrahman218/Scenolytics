def align_with_whisperx(audio_array, transcription, sample_rate=16000):
    """
    Accurate word-level alignment using WhisperX
    Works well with Egyptian Arabic
    """
    print("\n" + "="*60)
    print("Performing accurate alignment with WhisperX...")
    print("="*60)

    # Save audio temporarily
    temp_audio = "/content/temp_audio_for_alignment.wav"
    sf.write(temp_audio, audio_array, sample_rate)

    # Load audio in WhisperX format
    audio = whisperx.load_audio(temp_audio)

    # Step 1: Get initial transcription with timestamps from Whisper
    print("Step 1: Getting initial timestamps from Whisper...")
    result = whisperx_model.transcribe(audio, batch_size=16, language="ar")

    print(f"✓ Found {len(result['segments'])} segments")

    # Step 2: Align with Arabic model for word-level timestamps
    print("\nStep 2: Aligning word-level timestamps...")
    try:
        model_a, metadata = whisperx.load_align_model(language_code="ar", device=device)
        result_aligned = whisperx.align(
            result["segments"],
            model_a,
            metadata,
            audio,
            device,
            return_char_alignments=False
        )

        print("✓ Word-level alignment completed!")

        # Clean up alignment model
        del model_a
        gc.collect()
        torch.cuda.empty_cache()

    except Exception as e:
        print(f"⚠️ Alignment model failed: {e}")
        print("Using segment-level timestamps instead...")
        result_aligned = result

    # Extract word-level timestamps
    word_timestamps = []

    for segment in result_aligned["segments"]:
        # Check if we have word-level timestamps
        if "words" in segment and segment["words"]:
            for word_info in segment["words"]:
                if word_info.get("word", "").strip():
                    word_timestamps.append({
                        'word': word_info["word"].strip(),
                        'start': round(word_info["start"], 3),
                        'end': round(word_info["end"], 3),
                        'duration': round(word_info["end"] - word_info["start"], 3)
                    })
        else:
            # Fallback: use segment timestamps and split by words
            segment_text = segment["text"].strip()
            words = segment_text.split()

            if words:
                segment_duration = segment["end"] - segment["start"]
                word_duration = segment_duration / len(words)

                for i, word in enumerate(words):
                    word_start = segment["start"] + (i * word_duration)
                    word_end = word_start + word_duration

                    word_timestamps.append({
                        'word': word,
                        'start': round(word_start, 3),
                        'end': round(word_end, 3),
                        'duration': round(word_duration, 3)
                    })

    print(f"\n✓ Extracted {len(word_timestamps)} word timestamps")

    # Clean up
    os.remove(temp_audio)

    return word_timestamps

