            normalized_word = normalize_arabic(seg['word'])
            transcript_word_timestamps.append({
                'word': normalized_word,
                'start': seg['start'],
                'end': seg['end'],
                'duration': seg['duration']
            })
    else:
        print("⚠ No word-level timestamps available")

    # Use difflib to compare word by word
    matcher = difflib.SequenceMatcher(None, script_words, transcript_words)

    transcript_idx = 0
    position = 0

    for tag, i1, i2, j1, j2 in matcher.get_opcodes():
        if tag == 'equal':
            # Words match
            for i in range(i1, i2):
                # Get timestamp info if available
                ts_info = None
                timestamp = 'N/A'

                if transcript_idx < len(transcript_word_timestamps):
                    ts_info = transcript_word_timestamps[transcript_idx]
                    timestamp = f"{ts_info['start']:.2f}s"

                comparison_data.append({
                    'Position': position,
                    'Status': '✓ Match',
                    'Script Word': script_words[i],
                    'Transcript Word': transcript_words[j1 + (i - i1)],
                    'Timestamp': timestamp,
                    'Note': ''
                })
                position += 1
                transcript_idx += 1

        elif tag == 'replace':
            # Words changed
            max_len = max(i2 - i1, j2 - j1)
            for idx in range(max_len):
                script_word = script_words[i1 + idx] if (i1 + idx) < i2 else ''
                transcript_word = transcript_words[j1 + idx] if (j1 + idx) < j2 else ''

                # Get timestamp info if available
                ts_info = None
                timestamp = 'N/A'

                if transcript_word and transcript_idx < len(transcript_word_timestamps):
                    ts_info = transcript_word_timestamps[transcript_idx]
                    timestamp = f"{ts_info['start']:.2f}s"

                if script_word and transcript_word:
                    status = '🟡 Changed'
                    note = f'Changed from "{script_word}" to "{transcript_word}"'
                elif script_word and not transcript_word:
                    status = '🔴 Skipped'
                    note = f'Word "{script_word}" was skipped'
                    timestamp = 'N/A'
                else:
                    status = '🟢 Added'
                    note = f'Word "{transcript_word}" was added at {timestamp}'

                comparison_data.append({
                    'Position': position,
                    'Status': status,
                    'Script Word': script_word if script_word else '-',
                    'Transcript Word': transcript_word if transcript_word else '-',
                    'Timestamp': timestamp,
                    'Note': note
                })
                position += 1
                if transcript_word:
                    transcript_idx += 1

        elif tag == 'delete':
            # Words were skipped from script
            for i in range(i1, i2):
                comparison_data.append({
                    'Position': position,
                    'Status': '🔴 Skipped',
                    'Script Word': script_words[i],
                    'Transcript Word': '-',
                    'Timestamp': 'N/A',
                    'Note': f'Word "{script_words[i]}" was not said'
                })
                position += 1

        elif tag == 'insert':
            # Words were added to transcript
            for j in range(j1, j2):
                # Get timestamp info if available
                ts_info = None
                timestamp = 'N/A'

                if transcript_idx < len(transcript_word_timestamps):
                    ts_info = transcript_word_timestamps[transcript_idx]
                    timestamp = f"{ts_info['start']:.2f}s"

                comparison_data.append({
                    'Position': position,
                    'Status': '🟢 Added',
                    'Script Word': '-',
                    'Transcript Word': transcript_words[j],
                    'Timestamp': timestamp,
                    'Note': f'Word "{transcript_words[j]}" was added at {timestamp}'
                })
                position += 1
                transcript_idx += 1

    return pd.DataFrame(comparison_data), script_words, transcript_words


